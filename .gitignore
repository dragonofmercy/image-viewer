## Visual Studio temporary files, build results and tooling artifacts.
## Trimmed from the GitHub VisualStudio.gitignore template — only rules
## relevant to this WinUI 3 / .NET 8 / Velopack project are kept.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user

# JetBrains Rider / ReSharper
.idea/
_ReSharper*/
*.[Rr]e[Ss]harper

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache
.vs/

# Visual Studio auto-generated files
Generated\ Files/

# Files built by Visual Studio
*.ilk
*.pdb
*.ipdb
*.tmp
*.tmp_proj
*.log
*.binlog
*.[Cc]ache
!?*.[Cc]ache/

# NuGet
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# Backup files
~$*
*~

# Velopack output
Releases/
publish/
